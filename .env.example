# Copie este arquivo para ".env" (na raiz) e preencha com os valores reais.
# O .env NÃO é versionado (contém segredos: senhas, tokens).

# --- Banco de dados (MySQL) ---
DB_HOST=localhost
DB_NAME=nome_do_banco
DB_USER=usuario_do_banco
DB_PASS=senha_do_banco

# URL base do site, SEM barra no final.
BASE_URL=https://dolivier.com.br

# Ambiente: dev (mostra erros) | prod (esconde)
APP_ENV=prod

# --- Mercado Pago (fases futuras) ---
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
