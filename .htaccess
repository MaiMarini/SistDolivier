# Front controller: envia tudo que NÃO for arquivo/pasta real para o index.php.
# Mantém URLs limpas (ex.: /produto/vela-aromatica -> index.php).

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Se preciso, ajuste a base quando o site rodar em subpasta (ex.: RewriteBase /loja/).
    # RewriteBase /

    # Não reescreve arquivos existentes (CSS, JS, imagens, uploads...).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo o resto vai para o front controller.
    RewriteRule ^ index.php [L]
</IfModule>

# Página de erro 404 também passa pelo roteador.
ErrorDocument 404 /index.php

# Bloqueia listagem de diretórios.
Options -Indexes

# Nega acesso web a arquivos sensíveis (.env, .env.example, .git*, etc.).
# São arquivos reais, então a regra de reescrita os serviria — este bloco impede.
<FilesMatch "^\.(env|git)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
